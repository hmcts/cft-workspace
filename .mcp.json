{
  "mcpServers": {
    "atlassian": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--env-file", ".claude/.atlassian.env",
        "-e", "READ_ONLY_MODE=true",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}
