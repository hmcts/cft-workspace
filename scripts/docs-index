#!/usr/bin/env bash
# Regenerate DOCS.md — a workspace-level index of every Diátaxis page across
# all doc trees (docs/ + apps/*/docs/), so /cft-explain and /cft-how-to can
# route via grep instead of scanning every .md.
#
# Required frontmatter on every indexed page: title, topic, diataxis, product.
# Pages missing any of these are reported and cause a non-zero exit — run
# `./scripts/_backfill-frontmatter` to fix.
#
# Exempt (never indexed): README.md, anything under .work/, anything not under
# one of the four Diátaxis subdirs.

source "$(dirname "$0")/lib/_common.sh"

require_yq
cd "$WORKSPACE_ROOT"

DIATAXIS_LEVELS=(tutorials how-to reference explanation)

# Pull a scalar frontmatter field; empty string if missing.
field() {
    local fm="$1" key="$2"
    printf '%s' "$fm" | yq -r ".$key // \"\"" - 2>/dev/null
}

rows_tsv=$(mktemp)
missing=()
count=0

for root in docs apps/*/docs; do
    [[ -d "$root" ]] || continue
    for level in "${DIATAXIS_LEVELS[@]}"; do
        [[ -d "$root/$level" ]] || continue
        while IFS= read -r f; do
            count=$((count+1))
            fm=$(awk '/^---[[:space:]]*$/{c++; if(c==2)exit; if(c>0)next} c==1{print}' "$f")
            if [[ -z "$fm" ]]; then
                missing+=("$f (no frontmatter)")
                continue
            fi
            title=$(field "$fm" title)
            topic=$(field "$fm" topic)
            diataxis=$(field "$fm" diataxis)
            product=$(field "$fm" product)
            for v in "title:$title" "topic:$topic" "diataxis:$diataxis" "product:$product"; do
                [[ "${v#*:}" == "" ]] && missing+=("$f (missing ${v%:*})")
            done
            printf '%s\t%s\t%s\t%s\t%s\n' "$product" "$diataxis" "$title" "$topic" "$f" >> "$rows_tsv"
        done < <(find "$root/$level" -type f -name '*.md' ! -name 'README.md' ! -path '*/.work/*')
    done
done

if (( ${#missing[@]} > 0 )); then
    err "DOCS.md not regenerated — $count pages scanned, ${#missing[@]} need frontmatter:"
    for m in "${missing[@]}"; do err "  - $m"; done
    err ""
    err "Run ./scripts/_backfill-frontmatter to populate."
    rm -f "$rows_tsv"
    exit 1
fi

{
    printf '# cft-workspace docs index\n\n'
    printf 'Generated by `scripts/docs-index`. One row per Diátaxis page across `docs/` and every `apps/*/docs/`.\n\n'
    printf 'Skills `/cft-explain` and `/cft-how-to` grep this file to route questions.\n\n'
    printf '| Product | Diátaxis | Title | Topic | Path |\n'
    printf '|---|---|---|---|---|\n'
    # Sort by product, then diataxis (in canonical order), then title.
    # Diátaxis ordinal: tutorials=1, how-to=2, reference=3, explanation=4.
    awk -F'\t' '
        BEGIN{ord["tutorials"]=1; ord["how-to"]=2; ord["reference"]=3; ord["explanation"]=4}
        {printf "%s\t%d\t%s\t%s\t%s\t%s\n", $1, ord[$2], $2, $3, $4, $5}
    ' "$rows_tsv" | sort -t$'\t' -k1,1 -k2,2n -k4,4 | \
    awk -F'\t' '{printf "| %s | %s | %s | %s | `%s` |\n", $1, $3, $4, $5, $6}'
} > DOCS.md

rm -f "$rows_tsv"

ok "DOCS.md updated ($count pages indexed)"
