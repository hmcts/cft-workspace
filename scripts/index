#!/usr/bin/env bash
# Regenerate INDEX.md from each product's CLAUDE.md frontmatter.
#
# Walks every product directory (apps/*, libs/, platops/) that has a CLAUDE.md
# at its root, parses the YAML frontmatter, and rewrites INDEX.md.

source "$(dirname "$0")/lib/_common.sh"

require_yq
cd "$WORKSPACE_ROOT"

# Pull a frontmatter field; "—" if missing/blank. Caller is expected to use a
# yq expression that returns a scalar (use `join(", ")` for lists).
field() {
    local fm="$1" expr="$2"
    local v
    v=$(printf '%s\n' "$fm" | yq -r "$expr // \"\"" - 2>/dev/null) || v=""
    [[ -z "$v" || "$v" == "null" ]] && { printf -- '—'; return; }
    printf '%s' "$v"
}

ccd_summary() {
    local fm="$1"
    local based config decentralised features parts=()
    based=$(printf '%s\n' "$fm" | yq -r '.ccd_based // false' -)
    [[ "$based" != "true" ]] && { printf -- '—'; return; }
    config=$(field "$fm" '.ccd_config')
    [[ "$config" != "—" ]] && parts+=("$config")
    features=$(field "$fm" '.ccd_features | join(", ")')
    [[ "$features" != "—" ]] && parts+=("feat: $features")
    if (( ${#parts[@]} == 0 )); then printf -- '—'; else
        local IFS='; '; printf '%s' "${parts[*]}"
    fi
}

# Summarise the api_specs list. For 0 entries → "—". For ≤3 → show the spec
# basenames joined by commas. For >3 → "<N> specs" so the table stays scannable.
api_summary() {
    local fm="$1"
    local count names
    count=$(printf '%s\n' "$fm" | yq -r '.api_specs | length // 0' - 2>/dev/null)
    [[ -z "$count" || "$count" == "0" || "$count" == "null" ]] && { printf -- '—'; return; }
    if (( count <= 3 )); then
        # Strip the "<repo>:" prefix, keep just the spec filename.
        names=$(printf '%s\n' "$fm" | yq -r '.api_specs[] | sub("^.*:"; "") | sub("\.json$"; "")' - 2>/dev/null \
            | paste -sd ', ' -)
        printf '%s' "$names"
    else
        printf '%s specs' "$count"
    fi
}

# List every product directory that has a CLAUDE.md.
products=()
for d in apps/*/ libs/ platops/; do
    d="${d%/}"
    [[ -f "$d/CLAUDE.md" ]] && products+=("$d")
done

{
    printf '# cft-workspace index\n\n'
    printf 'Generated by `scripts/index`. Source of truth is each product'\''s `CLAUDE.md` frontmatter.\n\n'
    printf '## Products\n\n'
    printf '| Product | Service | Repos | CCD | Integrations | APIs |\n'
    printf '|---|---|---|---|---|---|\n'

    for p in "${products[@]}"; do
        # Extract frontmatter: everything between the first two '---' lines.
        fm=$(awk 'BEGIN{c=0} /^---[[:space:]]*$/{c++; next} c==1{print} c==2{exit}' "$p/CLAUDE.md")
        if [[ -z "$fm" ]]; then
            printf '| `%s` | _no frontmatter_ | — | — | — | — |\n' "$p"
            continue
        fi
        repo_count=$(printf '%s\n' "$fm" | yq -r '.repos | length // 0' - 2>/dev/null)
        printf '| `%s` | %s | %s | %s | %s | %s |\n' \
            "$p" \
            "$(field "$fm" '.service')" \
            "${repo_count:-0}" \
            "$(ccd_summary "$fm")" \
            "$(field "$fm" '.integrations | join(", ")')" \
            "$(api_summary "$fm")"
    done

    if (( ${#products[@]} == 0 )); then
        printf '\n_No product CLAUDE.md files found. Run `/generate-product-claude-md` to populate._\n'
    fi
} > INDEX.md

ok "INDEX.md updated (${#products[@]} products)"
