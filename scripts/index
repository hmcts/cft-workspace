#!/usr/bin/env bash
# Regenerate INDEX.md from each cloned repo's CLAUDE.md frontmatter.

source "$(dirname "$0")/lib/_common.sh"

require_yq
cd "$WORKSPACE_ROOT"

# Pull frontmatter field; "—" if missing/blank. List values get joined.
field() {
    local fm="$1" expr="$2"
    local v
    v=$(printf '%s\n' "$fm" | yq -r "$expr // \"\"" - 2>/dev/null) || v=""
    [[ -z "$v" || "$v" == "null" ]] && { printf -- '—'; return; }
    # Coalesce flow-list output ("[a, b]") and YAML list ("- a\n- b") into "a, b".
    printf '%s' "$v" | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g'
}

ccd_summary() {
    local fm="$1"
    local based config decentralised features parts=()
    based=$(printf '%s\n' "$fm" | yq -r '.ccd_based // false' -)
    [[ "$based" != "true" ]] && { printf -- '—'; return; }
    config=$(field "$fm" '.ccd_config')
    [[ "$config" != "—" ]] && parts+=("$config")
    decentralised=$(printf '%s\n' "$fm" | yq -r '.decentralised // false' -)
    [[ "$decentralised" == "true" ]] && parts+=("decentralised")
    features=$(field "$fm" '.ccd_features | join(", ")')
    [[ "$features" != "—" ]] && parts+=("feat: $features")
    if (( ${#parts[@]} == 0 )); then printf -- '—'; else
        local IFS='; '; printf '%s' "${parts[*]}"
    fi
}

{
    printf '# cft-workspace index\n\n'
    printf 'Generated by `scripts/index`. Source of truth is each repo'\''s `CLAUDE.md` frontmatter.\n\n'
    printf '## Repos\n\n'
    printf '| Path | Type | Service | CCD | Integrations | Runtime |\n'
    printf '|---|---|---|---|---|---|\n'

    n=0
    while IFS=$'\t' read -r path _url _ref _depth; do
        n=$((n+1))
        cm="$path/CLAUDE.md"
        if [[ ! -f "$cm" ]]; then
            printf '| `%s` | _no CLAUDE.md_ | — | — | — | — |\n' "$path"
            continue
        fi
        # Extract frontmatter: everything between the first two '---' lines.
        fm=$(awk 'BEGIN{c=0} /^---[[:space:]]*$/{c++; next} c==1{print} c==2{exit}' "$cm")
        if [[ -z "$fm" ]]; then
            printf '| `%s` | _no frontmatter_ | — | — | — | — |\n' "$path"
            continue
        fi
        printf '| `%s` | %s | %s | %s | %s | %s |\n' \
            "$path" \
            "$(field "$fm" '.type')" \
            "$(field "$fm" '.service')" \
            "$(ccd_summary "$fm")" \
            "$(field "$fm" '.integrations | join(", ")')" \
            "$(field "$fm" '.runtime')"
    done < <(manifest_tsv)
} > INDEX.md

ok "INDEX.md updated ($n repos)"
