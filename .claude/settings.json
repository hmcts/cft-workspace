{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./scripts/bootstrap*)",
      "Bash(./scripts/sync*)",
      "Bash(./scripts/doctor*)",
      "Bash(./scripts/grep*)",
      "Bash(./scripts/index*)",
      "Bash(./scripts/add-repo*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git ls-files*)",
      "Bash(git show*)",
      "Bash(gh auth status*)",
      "Bash(gh repo view*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(rg *)",
      "Bash(yq *)",
      "Bash(jq *)",
      "Bash(./gradlew test*)",
      "Bash(./gradlew check*)",
      "Bash(./gradlew tasks*)",
      "Bash(./gradlew dependencies*)",
      "Bash(yarn lint*)",
      "Bash(yarn test*)",
      "Bash(yarn typecheck*)",
      "Bash(npx eslint*)",
      "Bash(npx tsc*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Bash(./scripts/* --no-verify*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/doctor --quiet 2>&1 | head -20"
          }
        ]
      }
    ]
  }
}
